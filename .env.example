# ═══════════════════════════════════════════════════════════════
# Study Companion Environment Variables
# ═══════════════════════════════════════════════════════════════
# 
# REQUIRED: None! The app works 100% locally with Ollama.
#
# OPTIONAL: Add cloud API keys for fallback/faster generation.
# ═══════════════════════════════════════════════════════════════

# ─── Ollama (Local LLM - Required) ───────────────────────────
# Make sure Ollama is running: ollama serve
# Pull models: ollama pull llama3 && ollama pull phi3
OLLAMA_BASE_URL=http://localhost:11434

# ─── Cloud Fallbacks (Optional - Free Tiers) ─────────────────
# Groq: https://console.groq.com/ (free, very fast)
GROQ_API_KEY=

# OpenAI: https://openai.com (optional, paid)
OPENAI_API_KEY=